rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocument() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserDocument() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return hasUserDocument() && userDocument().data.role == 'admin';
    }

    function isPatient() {
      return hasUserDocument() && userDocument().data.role == 'patient';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role in ['patient', 'admin']
        && request.resource.data.status in ['active', 'inactive'];

      allow update: if isAdmin()
        || (
          isOwner(userId)
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.email == resource.data.email
          && request.resource.data.role == resource.data.role
        );

      allow delete: if isAdmin();
    }

    match /faqs/{faqId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /departments/{departmentId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /triage_rules/{ruleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /contact_info/{contactId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /chatbot_settings/{settingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow create: if isAdmin()
        || (
          isPatient()
          && request.resource.data.patientUid == request.auth.uid
          && request.resource.data.status == 'pending'
        );

      allow read: if isAdmin()
        || (
          isSignedIn()
          && resource.data.patientUid == request.auth.uid
        );

      allow update: if isAdmin()
        || (
          isPatient()
          && resource.data.patientUid == request.auth.uid
          && request.resource.data.patientUid == resource.data.patientUid
          && request.resource.data.status in ['pending', 'cancelled']
        );

      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
